#!/usr/bin/env bash
#------------------------------------------------------------------------------
#
# File:         upstream_kernel_builder_v6
#   
# Description:  Builds upstream Linux kernel and installs to a host running
#               Fedora. Supports explicit configure, clean, build, install,
#               and uninstall phases for an out-of-tree O= build.
#
# Prerequisites:
# --------------
# - Set env variables KERNEL_SRC_DIR and KERNEL_BUILD_DIR.
# - Clone mainline Linux into $KERNEL_SRC_DIR.
# - Copy a starting kernel config to $KERNEL_BUILD_DIR/.config.
# - Set up passwordless SSH and passwordless sudo on the target for install.
#
# Examples: 
# --------- 
# Configure and build:
#   $ ./upstream_kernel_builder_v6 -l chopin -a aarch64 -c \
#       -k ~/projects/orangepi5plus/upstream_kernel_config_opi5plus.txt -B
#
# Clean and rebuild:
#   $ ./upstream_kernel_builder_v6 -l chopin -a aarch64 -C -B
#
# Incremental rebuild:
#   $ ./upstream_kernel_builder_v6 -l chopin -a aarch64 -B
#
# Install-only:
#   $ ./upstream_kernel_builder_v6 -l chopin -t orthanc -i grub
#------------------------------------------------------------------------------

set -euo pipefail

TARGET_HOST=""
BUILD_ARCH="${BUILD_ARCH:-aarch64}"
KERNEL_RELEASE=""
INSTALL_MODE=""
DO_CONFIG=false
DO_CLEAN=false
DO_BUILD=false
DO_UNINSTALL=false
DEBUG_CONFIG=false
LOCALVERSION_TAG=""
KERNEL_CONFIG_FILE=""
LOCALVERSION=""
LOG_DIR="${LOG_DIR:-$HOME/logs}"
LOG_FILE=""

# DTB selection (override if needed)
DTS_VENDOR="${DTS_VENDOR:-rockchip}"
DTB_NAME="${DTB_NAME:-rk3588-orangepi-5-plus.dtb}"
DTB_BOOT_PATH="/boot/dtb/${DTS_VENDOR}/${DTB_NAME}"
DTB_BUILD_PATH="${KERNEL_BUILD_DIR}/arch/arm64/boot/dts/${DTS_VENDOR}/${DTB_NAME}"

BLACK=$(tput setaf 0)
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
LIME_YELLOW=$(tput setaf 190)
BLUE=$(tput setaf 4)
BRIGHT_BLUE=$(tput setaf 12)
POWDER_BLUE=$(tput setaf 153)
MAGENTA=$(tput setaf 5)
CYAN=$(tput setaf 6)
WHITE=$(tput setaf 7)
BRIGHT=$(tput bold)
NORMAL=$(tput sgr0)
BOLD=$(tput bold)
BLINK=$(tput blink)
REVERSE=$(tput smso)
UNDERLINE=$(tput smul)

if [[ -z "${KERNEL_SRC_DIR:-}" || -z "${KERNEL_BUILD_DIR:-}" ]]; then
    echo "${BOLD}${RED}Error: KERNEL_SRC_DIR and KERNEL_BUILD_DIR must be set"
    echo "${NORMAL}"
    exit 1
fi

usage()
{
    cat <<USAGE
Usage: $0 [options]

Options:
  -a <x86_64|aarch64|riscv64>   Architecture (default: aarch64)
  -t <target_host>              Target host for deployment (required for install/uninstall)
  -l <tag|none>                 Set CONFIG_LOCALVERSION to -<tag> (or empty for none)
  -k <config_file>              Apply Kconfig from file
  -c                            Configure kernel
  -C                            Clean build tree (make clean)
  -B                            Build the kernel (Image modules dtbs)
  -d                            Configure kernel for debugging (requires -c)
  -f                            Configure kernel for fast dev loop (requires -c)
  -i <boot|grub|extlinux|rpm>   Installation mode (focus: grub)
  -u                            Uninstall the selected build from target
  -h                            Help

Env:
  KERNEL_SRC_DIR=$KERNEL_SRC_DIR
  KERNEL_BUILD_DIR=$KERNEL_BUILD_DIR
USAGE
    exit 1
}

while getopts "a:t:l:k:cCBdhi:u" opt; do
    case $opt in
        a) BUILD_ARCH="$OPTARG" ;;
        t) TARGET_HOST="$OPTARG" ;;
        l) LOCALVERSION_TAG="$OPTARG" ;;
        k) KERNEL_CONFIG_FILE="$OPTARG" ;;
        c) DO_CONFIG=true ;;
        C) DO_CLEAN=true ;;
        B) DO_BUILD=true ;;
        d) DEBUG_CONFIG=true ;;
        i) INSTALL_MODE="$OPTARG" ;;
        u) DO_UNINSTALL=true ;;
        h) usage ;;
        *) usage ;;
    esac
done

status_begin()
{
  local msg="$1"
  printf "%s%s...%s" "${WHITE}" "$msg" "${NORMAL}"
}

status_end_ok()
{
  local msg="$1"
  printf "\r\033[2K%s%s... %sDone%s\n" "${WHITE}" "$msg" "${BOLD}${GREEN}" "${NORMAL}"
}

status_end_fail()
{
  local msg="$1" rc="${2:-1}"
  printf "\r\033[2K%s%s... %sFailed%s (rc=%s)\n" "${WHITE}" "$msg" "${BOLD}${RED}" "${NORMAL}" "$rc"
}

normalize_localversion()
{
    local s="$1"
    if [[ -z "$s" || "$s" == "none" ]]; then
        echo ""
    elif [[ "$s" == -* ]]; then
        echo "$s"
    else
        echo "-$s"
    fi
}

if [[ -n "$LOCALVERSION_TAG" ]]; then
    LOCALVERSION="$(normalize_localversion "$LOCALVERSION_TAG")"
fi

create_log_file()
{
    local ts gccv host
    ts="$(date +"%Y_%m_%d_%H%M")"
    gccv="$(gcc --version | head -n 1 || true)"
    host="$(hostname -s 2>/dev/null || echo unknown)"

    mkdir -p "$LOG_DIR"
    LOG_FILE="$LOG_DIR/upstream_kernel_build_${ts}.log"

    {
        echo "//---------------------------------------------------------------"
        echo "// Upstream Kernel Build"
        echo "// Date: $(date)"
        echo "// Host: ${host}"
        echo "// ARCH: ${BUILD_ARCH}"
        echo "// KERNEL_SRC_DIR =   ${KERNEL_SRC_DIR}"
        echo "// KERNEL_BUILD_DIR = ${KERNEL_BUILD_DIR}"
        echo "// GCC: ${gccv}"
        echo "// LOCALVERSION: ${LOCALVERSION}"
        echo "// KCONFIG FILE: ${KERNEL_CONFIG_FILE:-<none>}"
        echo "//---------------------------------------------------------------"
        echo
    } > "$LOG_FILE"
}

generate_ctags()
{
    echo "${WHITE}Generating ctags..."
    echo "${NORMAL}"

    mkdir -p ~/tmp
    rm -f "${KERNEL_BUILD_DIR}/tags"

    ctags --tag-relative=yes \
          --sort=yes \
          --recurse \
          --links=no \
          --languages=C,C++ \
          --c-kinds=+p \
          --fields=+iaS \
          --extras=+q \
          -f "${KERNEL_BUILD_DIR}/tags" \
          --exclude="*.o" \
          --exclude="*.so" \
          --exclude="*.a" \
          --exclude="*.bin" \
          --exclude="*.ko" \
          --exclude="*.mod" \
          --exclude="*.cmd" \
          --exclude="*.d" \
          --exclude="*.symtypes" \
          --exclude="*.order" \
          --exclude=".git/*" \
          --exclude="cscope.*" \
          --exclude="tags*" \
          --exclude="Module.symvers" \
          --exclude="vmlinux*" \
          "${KERNEL_SRC_DIR}"
}

validate_architecture()
{
    case "$BUILD_ARCH" in x86_64|aarch64|riscv64) : ;; *)
        echo "${BOLD}${RED}Error: Unsupported arch: ${CYAN}${BUILD_ARCH}"
        echo "${NORMAL}"
        exit 2
    esac
}

validate_install_mode()
{
    case "${1:-}" in ""|boot|grub|extlinux|rpm) : ;; *)
        echo "${BOLD}${RED}Error: Unsupported install mode: ${CYAN}$1"
        echo "${NORMAL}"
        exit 2
    esac
}

validate_local_commands()
{
    local REQUIRED_CMDS=(make ssh dracut awk sed blkid findmnt tar ctags grep)
    for cmd in "${REQUIRED_CMDS[@]}"; do
        command -v "$cmd" >/dev/null 2>&1 || { printf 'Missing cmd: %s\n' "$cmd" >&2; exit 127; }
    done
}

ensure_remote_sudo()
{
    ssh -o BatchMode=yes "$TARGET_HOST" 'sudo -n true' 2>/dev/null || {
        echo "${BOLD}${RED}Error: Remote sudo needs a password on ${CYAN}${TARGET_HOST}"
        echo "${NORMAL}"
        exit 2
    }
}

validate_remote_commands()
{
    ssh "${TARGET_HOST}" 'set -e
        miss=0
        for c in grubby dracut tar tee install chmod mkdir depmod dtc fdtoverlay; do
            sudo -n sh -lc "command -v $c >/dev/null 2>&1" || {
                echo "Missing on target (as root): $c"
                miss=1
            }
        done
        exit $miss
    '
}

setup_cross_compile()
{
    local host_arch; host_arch=$(uname -m)
    if [[ "$host_arch" != "$BUILD_ARCH" ]]; then
        echo "${WHITE}Cross-compiling $BUILD_ARCH on $host_arch${NORMAL}"
        case "$BUILD_ARCH" in
            aarch64) export CROSS_COMPILE=aarch64-linux-gnu- ;;
            riscv64) export CROSS_COMPILE=riscv64-linux-gnu- ;;
        esac
    fi
}

configure_kernel_for_debug()
{
    local cfg="${KERNEL_BUILD_DIR}/.config"
    local kconf="${KERNEL_SRC_DIR}/scripts/config"
    [[ -f "$cfg" ]] || { echo "ERROR: $cfg not found" >&2; return 2; }

    "$kconf" --file "$cfg" --enable DEBUG_KERNEL
    "$kconf" --file "$cfg" --enable DEBUG_INFO
    "$kconf" --file "$cfg" --enable DEBUG_INFO_DWARF5
    "$kconf" --file "$cfg" --disable DEBUG_INFO_DWARF4
    "$kconf" --file "$cfg" --enable GDB_SCRIPTS
    "$kconf" --file "$cfg" --enable FRAME_POINTER
    "$kconf" --file "$cfg" --enable STACKTRACE
    "$kconf" --file "$cfg" --enable DEBUG_FS
    "$kconf" --file "$cfg" --enable KALLSYMS --enable KALLSYMS_ALL
    "$kconf" --file "$cfg" --enable FTRACE --enable FUNCTION_TRACER --enable FUNCTION_GRAPH_TRACER
    "$kconf" --file "$cfg" --enable FTRACE_SYSCALLS --enable TRACING
    "$kconf" --file "$cfg" --enable PROVE_LOCKING --enable DEBUG_LOCK_ALLOC
    "$kconf" --file "$cfg" --enable DEBUG_SPINLOCK --enable DEBUG_MUTEXES
    "$kconf" --file "$cfg" --enable DEBUG_ATOMIC_SLEEP --enable SCHED_DEBUG
    "$kconf" --file "$cfg" --enable DYNAMIC_DEBUG
    "$kconf" --file "$cfg" --enable DEBUG_INFO_BTF --enable DEBUG_INFO_BTF_MODULES
    "$kconf" --file "$cfg" --disable MODULE_SIG_FORCE
    make -C "$KERNEL_SRC_DIR" O="$KERNEL_BUILD_DIR" ARCH=arm64 olddefconfig

    generate_ctags
}

configure_kernel_for_fast_dev()
{
    local cfg="${KERNEL_BUILD_DIR}/.config"
    local kconf="${KERNEL_SRC_DIR}/scripts/config"
    [[ -f "$cfg" ]] || { echo "ERROR: $cfg not found" >&2; return 2; }
    "$kconf" --file "$cfg" --disable WERROR
    "$kconf" --file "$cfg" --disable SECURITY_SELINUX
    "$kconf" --file "$cfg" --disable DEBUG_INFO_BTF
    "$kconf" --file "$cfg" --disable DEBUG_INFO_BTF_MODULES
    "$kconf" --file "$cfg" --disable MODULE_SIG_ALL
    "$kconf" --file "$cfg" --disable MODULE_SIG_FORCE
    "$kconf" --file "$cfg" --disable DEBUG_INFO
    "$kconf" --file "$cfg" --disable IKHEADERS
}

config_has_desired_localversion()
{
    local cfg="${KERNEL_BUILD_DIR}/.config"
    local desired="$LOCALVERSION"
    [[ -f "$cfg" ]] || return 1

    local current auto_disabled=1

    current="$(sed -n 's/^CONFIG_LOCALVERSION="\(.*\)"$/\1/p' "$cfg" | tail -n1)"

    if grep -Eq '^# CONFIG_LOCALVERSION_AUTO is not set$' "$cfg" || \
       grep -Eq '^CONFIG_LOCALVERSION_AUTO=n$' "$cfg"; then
        auto_disabled=0
    fi

    [[ "$current" == "$desired" && "$auto_disabled" -eq 0 ]]
}

apply_localversion_config()
{
    local cfg="${KERNEL_BUILD_DIR}/.config"
    local kconf="${KERNEL_SRC_DIR}/scripts/config"

    [[ -f "$cfg" ]] || { echo "ERROR: $cfg not found" >&2; return 2; }
    [[ -x "$kconf" ]] || { echo "ERROR: $kconf not found or not executable" >&2; return 2; }

    if config_has_desired_localversion; then
        return 0
    fi

    "$kconf" --file "$cfg" --set-str LOCALVERSION "$LOCALVERSION" --disable LOCALVERSION_AUTO
}

apply_configs()
{
    local cfg="${KERNEL_BUILD_DIR}/.config"
    local kconf="${KERNEL_SRC_DIR}/scripts/config"

    [[ -f "$cfg" ]] || { echo "Error: .config not found: ${cfg}" >&2; return 1; }
    [[ -x "$kconf" ]] || { echo "Error: scripts/config not found: ${kconf}" >&2; return 1; }

    if [[ ! -f "${KERNEL_CONFIG_FILE}" ]]; then
        echo "Error: config file not found: ${KERNEL_CONFIG_FILE}" >&2
        return 1
    fi

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "${line}" || "${line}" =~ ^[[:space:]]*# ]] && continue

        local action symbol value
        action=""
        symbol=""
        value=""
        read -r action symbol value <<< "$line"

        if [[ -z "$action" || -z "$symbol" ]]; then
            echo "Error: malformed line: ${line}" >&2
            return 1
        fi

        local matches
        matches="$(grep -Rwl --include='Kconfig*' \
            -e "^[[:space:]]*config[[:space:]]\+${symbol}$" \
            -e "^[[:space:]]*menuconfig[[:space:]]\+${symbol}$" \
            "${KERNEL_SRC_DIR}" 2>/dev/null || true)"

        if [[ -z "$matches" ]]; then
            echo "Error: Unknown Kconfig symbol: ${symbol}" >&2
            return 1
        fi

        local -a cmd=( "$kconf" --file "$cfg" "--${action}" "$symbol" )
        [[ -n "$value" ]] && cmd+=( "$value" )

        "${cmd[@]}" || {
            echo "Error: failed to apply: ${line}" >&2
            return 1
        }
    done < "$KERNEL_CONFIG_FILE"
}

configure_kernel()
{
    local rc

    echo "${WHITE}Configuring kernel:${NORMAL}"

    status_begin "   - Verifying $KERNEL_BUILD_DIR/.config"
    if [[ -f "$KERNEL_BUILD_DIR/.config" ]]; then
        status_end_ok "   - Verifying $KERNEL_BUILD_DIR/.config"
    else
        status_end_fail "   - Verifying $KERNEL_BUILD_DIR/.config" "2"
        echo "${BOLD}${RED}Error: No .config in ${CYAN}${KERNEL_BUILD_DIR}"
        echo "${NORMAL}"
        exit 2
    fi

    status_begin "   - Normalizing config"
    if make -C "$KERNEL_SRC_DIR" O="$KERNEL_BUILD_DIR" ARCH=arm64 olddefconfig >>"$LOG_FILE" 2>&1; then
        status_end_ok "   - Normalizing config"
    else
        rc=$?; status_end_fail "   - Normalizing config" "$rc"; return "$rc"
    fi

    if [[ -n "$LOCALVERSION_TAG" ]]; then
        status_begin "   - Applying localversion config"
        if apply_localversion_config >>"$LOG_FILE" 2>&1; then
            status_end_ok "   - Applying localversion config"
        else
            rc=$?; status_end_fail "   - Applying localversion config" "$rc"; return "$rc"
        fi
    fi

    if [[ -n "$KERNEL_CONFIG_FILE" ]]; then
        status_begin "   - Applying config file"
        if apply_configs >>"$LOG_FILE" 2>&1; then
            status_end_ok "   - Applying config file"
        else
            rc=$?; status_end_fail "   - Applying config file" "$rc"; return "$rc"
        fi
    fi

    if [[ "$DEBUG_CONFIG" == true ]]; then
        status_begin "   - Applying debug config"
        if configure_kernel_for_debug >>"$LOG_FILE" 2>&1; then
            status_end_ok "   - Applying debug config"
        else
            rc=$?; status_end_fail "   - Applying debug config" "$rc"; return "$rc"
        fi
    fi

    status_begin "   - Normalizing config again"
    if make -C "$KERNEL_SRC_DIR" O="$KERNEL_BUILD_DIR" ARCH=arm64 olddefconfig >>"$LOG_FILE" 2>&1; then
        status_end_ok "   - Normalizing config again"
    else
        rc=$?; status_end_fail "   - Normalizing config again" "$rc"; return "$rc"
    fi

    echo ""
}

clean_kernel()
{
    local rc

    echo "${WHITE}Cleaning kernel build:${NORMAL}"
    status_begin "   - Cleaning build tree"
    if make -C "$KERNEL_SRC_DIR" O="$KERNEL_BUILD_DIR" ARCH=arm64 clean >>"$LOG_FILE" 2>&1; then
        status_end_ok "   - Cleaning build tree"
    else
        rc=$?
        status_end_fail "   - Cleaning build tree" "$rc"
        return "$rc"
    fi
    echo ""
}

get_kernel_release()
{
    make -s -C "$KERNEL_SRC_DIR" O="$KERNEL_BUILD_DIR" ARCH=arm64 kernelrelease
}

ensure_localversion_matches_for_build()
{
    if [[ -z "$LOCALVERSION_TAG" ]]; then
        return 0
    fi

    if config_has_desired_localversion; then
        return 0
    fi

    local cfg="${KERNEL_BUILD_DIR}/.config"
    local current
    current="$(sed -n 's/^CONFIG_LOCALVERSION="\(.*\)"$/\1/p' "$cfg" | tail -n1)"

    echo "Error: .config LOCALVERSION state does not match requested value." >&2
    echo "  requested: ${LOCALVERSION}" >&2
    echo "  current:   ${current:-<unset>}" >&2
    echo "  note:      CONFIG_LOCALVERSION_AUTO may still be enabled" >&2
    echo "Run with -c first to update the config." >&2
    return 2
}

build_symbol_dtb()
{
    local rc
    local label="   - Building DTB with symbols (-@): ${DTB_NAME}"

    rm -f "$DTB_BUILD_PATH"

    status_begin "$label"
    if make -C "$KERNEL_SRC_DIR" -j"$(nproc)" O="$KERNEL_BUILD_DIR" ARCH=arm64 \
        V=1 "${DTS_VENDOR}/${DTB_NAME}" DTC_FLAGS="-@" >>"$LOG_FILE" 2>&1; then
        status_end_ok "$label"
    else
        rc=$?
        status_end_fail "$label" "$rc"
        return "$rc"
    fi

    status_begin "   - Verifying built DTB contains /__symbols__"
    if command -v fdtget >/dev/null 2>&1; then
        if fdtget -l "$DTB_BUILD_PATH" /__symbols__ >/dev/null 2>&1; then
            status_end_ok "   - Verifying built DTB contains /__symbols__"
        else
            rc=$?
            status_end_fail "   - Verifying built DTB contains /__symbols__" "$rc"
            echo "ERROR: Built DTB is missing /__symbols__: $DTB_BUILD_PATH" >&2
            return 1
        fi
    else
        if "$KERNEL_SRC_DIR/scripts/dtc/dtc" -@ -I dtb -O dts -o - "$DTB_BUILD_PATH" | grep -q '^/__symbols__'; then
            status_end_ok "   - Verifying built DTB contains /__symbols__"
        else
            rc=$?
            status_end_fail "   - Verifying built DTB contains /__symbols__" "$rc"
            echo "ERROR: Built DTB is missing /__symbols__: $DTB_BUILD_PATH" >&2
            return 1
        fi
    fi
}

build_kernel()
{
    local rc
    local start end dur

    echo "${WHITE}Building kernel:${NORMAL}"
    echo "${WHITE}   - Log file: ${CYAN}${LOG_FILE}${NORMAL}"

    status_begin "   - Preparing cross-compile environment"
    if setup_cross_compile >/dev/null 2>&1; then
        status_end_ok "   - Preparing cross-compile environment"
    else
        rc=$?; status_end_fail "   - Preparing cross-compile environment" "$rc"; return "$rc"
    fi

    status_begin "   - Verifying localversion config"
    if ensure_localversion_matches_for_build >>"$LOG_FILE" 2>&1; then
        status_end_ok "   - Verifying localversion config"
    else
        rc=$?; status_end_fail "   - Verifying localversion config" "$rc"; return "$rc"
    fi

    local -a MAKE_CMD=(
        make -C "$KERNEL_SRC_DIR" -j"$(nproc)"
        O="$KERNEL_BUILD_DIR" ARCH=arm64
        Image modules dtbs
    )

    {
        echo
        echo "== Build begin"
        echo "   When:   $(date '+%F %T')"
        echo -n "   Cmd:    "
        printf '%q ' "${MAKE_CMD[@]}"
        echo
        echo "   Log:    $LOG_FILE"
    } >>"$LOG_FILE"

    status_begin "   - Building kernel (Image, modules, DTBs)"
    start="$(date +%s)"
    if "${MAKE_CMD[@]}" >>"$LOG_FILE" 2>&1; then
        end="$(date +%s)"; dur=$(( end - start ))
        {
            echo "== Build end"
            echo "   When:   $(date '+%F %T')"
            echo "   Elapsed: $((dur/60))m $((dur%60))s"
        } >>"$LOG_FILE"
        status_end_ok "   - Building kernel (Image, modules, DTBs)"
    else
        rc=$?
        end="$(date +%s)"; dur=$(( end - start ))
        {
            echo "== Build end [FAILED rc=${rc}]"
            echo "   When:   $(date '+%F %T')"
            echo "   Elapsed: $((dur/60))m $((dur%60))s"
        } >>"$LOG_FILE"
        status_end_fail "   - Building kernel (Image, modules, DTBs)" "$rc"
        return "$rc"
    fi

    build_symbol_dtb || return $?

    status_begin "   - Determining kernel release"
    KERNEL_RELEASE="$(get_kernel_release)"
    if [[ -n "$KERNEL_RELEASE" ]]; then
        {
            echo
            echo "// KERNEL_RELEASE: ${KERNEL_RELEASE}"
        } >>"$LOG_FILE"
        status_end_ok "   - Determining kernel release"
    else
        status_end_fail "   - Determining kernel release" "1"
        return 1
    fi

    echo ""
}

create_and_install_initramfs()
{
    local SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"
    local REDIR="${LOG_FILE:-/dev/null}"
    local rc

    status_begin "   - Creating initramfs on target"
    if ssh $SSH_OPTS "$TARGET_HOST" "sudo dracut '/boot/initramfs-$KERNEL_RELEASE.img' '$KERNEL_RELEASE' --force" >>"$REDIR" 2>&1; then
        status_end_ok "   - Creating initramfs on target"
    else
        rc=$?; status_end_fail "   - Creating initramfs on target" "$rc"; return "$rc"
    fi
}

install_kernel_to_boot_partition()
{
    local SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"
    local rc

    [[ -n "${KERNEL_RELEASE:-}" ]] || KERNEL_RELEASE="$(get_kernel_release)"

    local STAGE="$KERNEL_BUILD_DIR/stage"
    status_begin "   - Cleaning staging dir"
    if rm -rf "$STAGE" && mkdir -p "$STAGE"; then
        status_end_ok "   - Cleaning staging dir"
    else rc=$?; status_end_fail "   - Cleaning staging dir" "$rc"; return "$rc"; fi

    if ! find "$KERNEL_BUILD_DIR" -name '*.ko' -print -quit 2>/dev/null | grep -q .; then
        status_begin "   - Building modules (first-time)"
        if make -C "$KERNEL_SRC_DIR" O="$KERNEL_BUILD_DIR" ARCH=arm64 modules >>"$LOG_FILE" 2>&1; then
            status_end_ok "   - Building modules (first-time)"
        else rc=$?; status_end_fail "   - Building modules (first-time)" "$rc"; return "$rc"; fi
    else
        status_begin "   - Skipping module rebuild (already built)"
        status_end_ok "   - Skipping module rebuild (already built)"
    fi

    status_begin "   - Staging modules"
    if make -C "$KERNEL_SRC_DIR" O="$KERNEL_BUILD_DIR" ARCH=arm64 \
           modules_install INSTALL_MOD_PATH="$STAGE" >>"$LOG_FILE" 2>&1; then
        status_end_ok "   - Staging modules"
    else rc=$?; status_end_fail "   - Staging modules" "$rc"; return "$rc"; fi

    status_begin "   - Copying modules"
    if tar -C "$STAGE/lib/modules" -cf - "$KERNEL_RELEASE" | ssh $SSH_OPTS "$TARGET_HOST" "sudo tar -C /lib/modules -xpf -"; then
        status_end_ok "   - Copying modules"
    else rc=$?; status_end_fail "   - Copying modules" "$rc"; return "$rc"; fi

    status_begin "   - Running depmod on target"
    if ssh $SSH_OPTS "$TARGET_HOST" "sudo depmod -a '$KERNEL_RELEASE'"; then
        status_end_ok "   - Running depmod on target"
    else rc=$?; status_end_fail "   - Running depmod on target" "$rc"; return "$rc"; fi

    status_begin "   - Copying kernel image"
    if ssh $SSH_OPTS "$TARGET_HOST" \
         "sudo install -m 0644 /dev/stdin '/boot/Image-$KERNEL_RELEASE' && \
          (command -v restorecon >/dev/null 2>&1 && sudo restorecon -F '/boot/Image-$KERNEL_RELEASE' || true)" \
       < "$KERNEL_BUILD_DIR/arch/arm64/boot/Image"; then
        status_end_ok "   - Copying kernel image"
    else rc=$?; status_end_fail "   - Copying kernel image" "$rc"; return "$rc"; fi

    status_begin "   - Backing up existing DTB"
    if ssh $SSH_OPTS "$TARGET_HOST" "sudo sh -c '
        set -e
        if [ -f \"${DTB_BOOT_PATH}\" ]; then
            cp -a \"${DTB_BOOT_PATH}\" \"${DTB_BOOT_PATH}.pre-${KERNEL_RELEASE}\"
        fi
    '" >>"$LOG_FILE" 2>&1; then
        status_end_ok "   - Backing up existing DTB"
    else
        rc=$?
        status_end_fail "   - Backing up existing DTB" "$rc"
    fi

    status_begin "   - Copying DTB (${DTB_NAME}) to ${DTB_BOOT_PATH}"
    if ssh $SSH_OPTS "$TARGET_HOST" \
         "sudo install -D -m 0644 /dev/stdin '${DTB_BOOT_PATH}' && \
          (command -v restorecon >/dev/null 2>&1 && sudo restorecon -F '${DTB_BOOT_PATH}' || true)" \
       < "$DTB_BUILD_PATH"; then
        status_end_ok "   - Copying DTB (${DTB_NAME}) to ${DTB_BOOT_PATH}"
    else
        rc=$?; status_end_fail "   - Copying DTB (${DTB_NAME}) to ${DTB_BOOT_PATH}" "$rc"; return "$rc"
    fi

    status_begin "   - Verifying DTB contains /__symbols__"
    if ssh $SSH_OPTS "$TARGET_HOST" \
         "sudo dtc -I dtb -O dts -o - '${DTB_BOOT_PATH}' 2>/dev/null | grep -q '__symbols__'"; then
        status_end_ok "   - Verifying DTB contains /__symbols__"
    else
        rc=$?; status_end_fail "   - Verifying DTB contains /__symbols__" "$rc"
        echo "ERROR: Installed DTB is missing /__symbols__. Overlay application will fail." >&2
        return 1
    fi

    create_and_install_initramfs || return $?
}

install_kernel_for_grub()
{
    local SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"
    [[ -n "$KERNEL_RELEASE" ]] || KERNEL_RELEASE="$(get_kernel_release)"

    echo "${WHITE}Installing on ${CYAN}${TARGET_HOST}${NORMAL}:"

    local label rc CMDLINE
    label="   - Installing to boot partition"
    status_begin "$label"
    if install_kernel_to_boot_partition; then
        status_end_ok "$label"
    else
        rc=$?; status_end_fail "$label" "$rc"; return "$rc"
    fi

    label="   - Reading current kernel cmdline from target"
    status_begin "$label"
    CMDLINE="$(ssh $SSH_OPTS "$TARGET_HOST" 'cat /proc/cmdline | sed -E "s/ ?BOOT_IMAGE=[^ ]+//"')"
    status_end_ok "$label"

    label="   - Creating GRUB entry via grubby"
    status_begin "$label"
    if ssh $SSH_OPTS "$TARGET_HOST" "sudo grubby \
            --add-kernel=/boot/Image-$KERNEL_RELEASE \
            --initrd=/boot/initramfs-$KERNEL_RELEASE.img \
            --title=\"Linux mainline ($KERNEL_RELEASE)\" \
            --args=\"$CMDLINE\"" >>"$LOG_FILE" 2>&1; then
        status_end_ok "$label"
    else
        rc=$?; status_end_fail "$label" "$rc"; return "$rc"
    fi

    echo ""
    echo "${WHITE}Now run on the target:"
    echo "${CYAN}$ sudo grubby --info=ALL"
    echo "${CYAN}$ sudo grubby --set-default /boot/Image-<version>"
    echo "${CYAN}$ sudo grubby --default-kernel"
    echo "${CYAN}$ sudo reboot"
    echo "${CYAN}$ uname -r"
    echo "${NORMAL}"
}

